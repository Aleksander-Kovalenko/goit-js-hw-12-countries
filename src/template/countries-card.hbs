<div class="card">
    <div class="card-img-top">
        <img src="{{flag}}" alt="{{name}}">
    </div>
    <div class="card-body">
        <h2 class="card-title">Capital: {{capital}}</h2>
        <p class="card-text">Population: {{population}}</p>

        <p class="card-text"><b>Languages:</b></p>
        <ul class="list-group">
            {{#each languages}}
            <li class="list-group-item">{{name}}</li>
            {{/each}}
        </ul>
    </div>
</div>